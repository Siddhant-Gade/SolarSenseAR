# SolarSense AR Backend — Environment Variables
# Copy this file to .env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/solarsense

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-secure-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AWS S3 (optional) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=solarsense-snapshots
S3_REGION=ap-south-1

# ── Solar constants ───────────────────────────────────────────────────────────
COST_PER_KW_INR=60000
GRID_RATE_PER_UNIT=8.0
PANEL_WATT=550
